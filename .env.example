# Copie para .env.local e preencha com os seus valores.

# Porta do servidor (padrao: 2001)
PORT=2001

# Provedor padrao da tela: openrouter | openai
AI_PROVIDER=openrouter

# OpenRouter (fica so no servidor, nunca vai pro browser).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# OpenAI (fica so no servidor, nunca vai pro browser).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Idioma da mensagem de commit: en | pt
COMMIT_LANGUAGE=en
