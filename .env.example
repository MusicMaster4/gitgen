# Copy to .env.local and fill in your values.

# Server port (default: 2001)
PORT=2001

# Default UI provider: openrouter | openai
AI_PROVIDER=openrouter

# OpenRouter (server-side only — never sent to the browser).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# OpenAI (server-side only — never sent to the browser).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Commit message language: en | pt
COMMIT_LANGUAGE=en